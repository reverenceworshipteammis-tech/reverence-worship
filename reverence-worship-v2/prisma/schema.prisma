generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  male
  female
  other
}

enum UserStatus {
  pending
  active
  inactive
}

enum MembershipType {
  permanent
  temporary
  visitor
}

model User {
  id              Int             @id @default(autoincrement())
  name            String
  email           String          @unique
  passwordHash    String?         @map("password_hash")
  mustChangePassword Boolean      @default(false) @map("must_change_password")
  status          UserStatus      @default(pending)
  emailVerifiedAt DateTime?       @map("email_verified_at")
  phone           String?
  dateOfBirth     DateTime?       @map("date_of_birth") @db.Date
  province        String?
  district        String?
  sector          String?
  village         String?
  gender          Gender?
  maritalStatus   String?         @map("marital_status")
  membershipType  MembershipType? @map("membership_type")
  occupation      String?
  ministryRole    String?         @map("ministry_role")
  emergencyName   String?         @map("emergency_name")
  emergencyPhone  String?         @map("emergency_phone")
  skills          String?
  notes           String?
  isSinger        Boolean         @default(false) @map("is_singer")
  voicePart       String?         @map("voice_part")
  singerLevel     String?         @map("singer_level")
  singerNotes     String?         @map("singer_notes")
  googleId        String?         @unique @map("google_id")
  avatarUrl       String?         @map("avatar_url")
  createdById     Int?            @map("created_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  createdBy                   User?                   @relation("CreatedUsers", fields: [createdById], references: [id], onDelete: SetNull)
  created                     User[]                  @relation("CreatedUsers")
  roles                       UserRole[]
  logs                        ActivityLog[]
  familyMembership            FamilyMember?
  parentFamily                Family?                 @relation("FamilyParent")
  assignedFamilyTasks         FamilyTask[]            @relation("AssignedFamilyTasks")
  createdActionPlans          ActionPlan[]            @relation("CreatedActionPlans")
  assignedActionPlanTasks     ActionPlanTask[]        @relation("AssignedActionPlanTasks")
  attendanceRecords           AttendanceRecord[]      @relation("AttendanceUser")
  markedAttendanceRecords     AttendanceRecord[]      @relation("AttendanceMarker")
  completedAttendanceSessions AttendanceSession[]     @relation("AttendanceSessionCompleter")
  permissionRequests          PermissionRequest[]     @relation("PermissionRequester")
  approvedPermissionRequests  PermissionRequest[]     @relation("PermissionApprover")
  disciplineRecords           DisciplineRecord[]      @relation("DisciplineUser")
  recordedDisciplineRecords   DisciplineRecord[]      @relation("DisciplineRecorder")
  resolvedDisciplineRecords   DisciplineRecord[]      @relation("DisciplineResolver")
  createdPlaylists            Playlist[]              @relation("CreatedPlaylists")
  createdSongs                Song[]                  @relation("CreatedSongs")
  createdGallery              PhotoGallery[]          @relation("CreatedGallery")
  createdServiceTeams         ServiceTeam[]           @relation("CreatedServiceTeams")
  teamMemberships             TeamMember[]
  createdBoardItems           PublicBoardItem[]       @relation("CreatedBoardItems")
  createdLandingVideos        LandingYoutubeVideo[]   @relation("CreatedLandingVideos")
  createdFeaturedImages       LandingFeaturedImage[]  @relation("CreatedFeaturedImages")
  createdSpiritualForms       SpiritualForm[]         @relation("CreatedSpiritualForms")
  formSubmissions             FormSubmission[]
  contributions               Contribution[]          @relation("ContributionUser")
  createdContributions        Contribution[]          @relation("ContributionCreator")
  payments                    Payment[]               @relation("PaymentUser")
  createdPayments             Payment[]               @relation("PaymentCreator")
  createdGifts                Gift[]                  @relation("GiftCreator")
  createdExpenses             Expense[]               @relation("ExpenseCreator")
  approvedExpenses            Expense[]               @relation("ExpenseApprover")
  firstApprovalExpenses       Expense[]               @relation("ExpenseFirstApprover")
  secondApprovalExpenses      Expense[]               @relation("ExpenseSecondApprover")
  voidedExpenses              Expense[]               @relation("ExpenseVoider")
  requestedExpenseVoids       Expense[]               @relation("ExpenseVoidRequester")
  financeReconciliations      FinanceReconciliation[] @relation("FinanceReconciler")
  createdSponsors             Sponsor[]               @relation("SponsorCreator")
  createdSponsorPayments      SponsorPayment[]        @relation("SponsorPaymentCreator")
  createdAnnouncements        Announcement[]          @relation("CreatedAnnouncements")
  publishedAnnouncements      Announcement[]          @relation("PublishedAnnouncements")
  announcementReads           AnnouncementUserRead[]
  notifications               Notification[]
  emailDeliveries             EmailDelivery[]
  passwordResetTokens         PasswordResetToken[]

  @@index([status])
  @@index([membershipType])
  @@index([isSinger])
  @@map("users")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model Family {
  id              Int       @id @default(autoincrement())
  name            String
  parentName      String?   @map("parent_name")
  description     String?
  motto           String?
  meetingDay      String?   @map("meeting_day")
  meetingTime     DateTime? @map("meeting_time") @db.Time
  meetingLocation String?   @map("meeting_location")
  createdBy       Int?      @map("created_by")
  isActive        Boolean   @default(true) @map("is_active")
  parentId        Int?      @unique @map("parent_id")
  year            Int       @default(2026)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  parent      User?          @relation("FamilyParent", fields: [parentId], references: [id], onDelete: SetNull)
  members     FamilyMember[]
  tasks       FamilyTask[]
  actionPlans ActionPlan[]

  @@map("families")
}

model FamilyMember {
  id        Int      @id @default(autoincrement())
  familyId  Int      @map("family_id")
  userId    Int      @unique @map("user_id")
  role      String   @default("member")
  joinedAt  DateTime @default(now()) @map("joined_at")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([familyId])
  @@map("family_members")
}

model FamilyTask {
  id          Int       @id @default(autoincrement())
  familyId    Int       @map("family_id")
  title       String
  description String?
  dueDate     DateTime? @map("due_date") @db.Date
  assignedTo  Int?      @map("assigned_to")
  status      String    @default("pending")
  priority    String    @default("medium")
  createdBy   Int?      @map("created_by")
  progress    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  family   Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  assignee User?         @relation("AssignedFamilyTasks", fields: [assignedTo], references: [id], onDelete: SetNull)
  subtasks TaskSubtask[]

  @@index([familyId])
  @@index([assignedTo])
  @@map("family_tasks")
}

model TaskSubtask {
  id          BigInt    @id @default(autoincrement())
  taskId      Int       @map("task_id")
  title       String
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  task FamilyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_subtasks")
}

model ActionPlan {
  id          Int      @id @default(autoincrement())
  familyId    Int?     @map("family_id")
  title       String
  description String?
  startDate   DateTime @map("start_date") @db.Date
  dueDate     DateTime @map("due_date") @db.Date
  status      String   @default("pending")
  priority    String   @default("medium")
  department  String   @default("social-fellowship")
  year        Int      @default(2026)
  progress    Int      @default(0)
  createdBy   Int?     @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  family  Family?          @relation(fields: [familyId], references: [id], onDelete: SetNull)
  creator User?            @relation("CreatedActionPlans", fields: [createdBy], references: [id], onDelete: SetNull)
  tasks   ActionPlanTask[]

  @@index([familyId])
  @@index([department])
  @@index([year])
  @@index([status])
  @@map("action_plans")
}

model ActionPlanTask {
  id              Int       @id @default(autoincrement())
  actionPlanId    Int       @map("action_plan_id")
  taskName        String    @map("task_name")
  activity        String?
  targetMilestone String?   @map("target_milestone")
  estimatedBudget Decimal   @default(0) @map("estimated_budget") @db.Decimal(15, 2)
  startDate       DateTime? @map("start_date") @db.Date
  deadline        DateTime? @db.Date
  priority        String    @default("medium")
  progress        Int       @default(0)
  assignedTo      Int?      @map("assigned_to")
  status          String    @default("pending")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  actionPlan ActionPlan @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
  assignee   User?      @relation("AssignedActionPlanTasks", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([actionPlanId])
  @@index([assignedTo])
  @@index([status])
  @@map("action_plan_tasks")
}

model FinanceTermSetting {
  id              Int      @id @default(autoincrement())
  currentYear     Int?     @default(2026) @map("current_year")
  numberOfTerms   Int?     @default(3) @map("number_of_terms")
  termPercentages String?  @default("[40,30,30]") @map("term_percentages")
  termNumbers     String?  @default("[1,2,3]") @map("term_numbers")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("finance_term_settings")
}

model Contribution {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  annualAmount Decimal? @default(0) @map("annual_amount") @db.Decimal(15, 2)
  year         Int
  notes        String?
  status       String?  @default("active")
  createdBy    Int?     @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user    User  @relation("ContributionUser", fields: [userId], references: [id], onDelete: Cascade)
  creator User? @relation("ContributionCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([userId, year])
  @@index([year])
  @@map("contributions")
}

model Payment {
  id              Int      @id @default(autoincrement())
  userId          Int?     @map("user_id")
  amount          Decimal  @db.Decimal(15, 2)
  paymentDate     DateTime @default(now()) @map("payment_date") @db.Date
  paymentMethod   String?  @map("payment_method")
  term            Int?
  referenceNumber String?  @map("reference_number")
  status          String?  @default("completed")
  notes           String?
  createdBy       Int?     @map("created_by")
  year            Int
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user    User? @relation("PaymentUser", fields: [userId], references: [id], onDelete: SetNull)
  creator User? @relation("PaymentCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([year])
  @@map("payments")
}

model Gift {
  id               Int       @id @default(autoincrement())
  donorName        String    @map("donor_name")
  commitmentAmount Decimal?  @default(0) @map("commitment_amount") @db.Decimal(15, 2)
  receivedAmount   Decimal?  @default(0) @map("received_amount") @db.Decimal(15, 2)
  giftType         String?   @map("gift_type")
  date             DateTime? @db.Date
  status           String?   @default("pending")
  notes            String?
  createdBy        Int?      @map("created_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  creator User? @relation("GiftCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("gifts")
}

model Expense {
  id              Int       @id @default(autoincrement())
  category        String?
  description     String?
  amount          Decimal   @db.Decimal(15, 2)
  date            DateTime? @default(now()) @db.Date
  status          String?   @default("pending")
  approvedBy      Int?      @map("approved_by")
  receiptPath     String?   @map("receipt_path")
  referenceNumber String?   @map("reference_number")
  rejectionReason String?   @map("rejection_reason")
  voidReason      String?   @map("void_reason")
  voidedAt        DateTime? @map("voided_at")
  voidedBy        Int?      @map("voided_by")
  voidRequestedAt DateTime? @map("void_requested_at")
  voidRequestedBy Int?      @map("void_requested_by")
  notes           String?
  createdBy       Int?      @map("created_by")
  approverId1     Int?      @map("approver_id_1")
  approverId2     Int?      @map("approver_id_2")
  year            Int?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  creator        User? @relation("ExpenseCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  approver       User? @relation("ExpenseApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  firstApprover  User? @relation("ExpenseFirstApprover", fields: [approverId1], references: [id], onDelete: SetNull)
  secondApprover User? @relation("ExpenseSecondApprover", fields: [approverId2], references: [id], onDelete: SetNull)
  voider         User? @relation("ExpenseVoider", fields: [voidedBy], references: [id], onDelete: SetNull)
  voidRequester  User? @relation("ExpenseVoidRequester", fields: [voidRequestedBy], references: [id], onDelete: SetNull)

  @@index([year])
  @@index([status])
  @@map("expenses")
}

model FinanceReconciliation {
  id           Int      @id @default(autoincrement())
  sourceType   String   @map("source_type")
  sourceId     Int      @map("source_id")
  reference    String?
  notes        String?
  reconciledBy Int      @map("reconciled_by")
  reconciledAt DateTime @default(now()) @map("reconciled_at")

  reconciler User @relation("FinanceReconciler", fields: [reconciledBy], references: [id], onDelete: Restrict)

  @@unique([sourceType, sourceId])
  @@index([reconciledAt])
  @@map("finance_reconciliations")
}

model Sponsor {
  id               Int      @id @default(autoincrement())
  name             String
  email            String?
  phone            String?
  commitmentAmount Decimal? @default(0) @map("commitment_amount") @db.Decimal(15, 2)
  receivedAmount   Decimal? @default(0) @map("received_amount") @db.Decimal(15, 2)
  fundType         String?  @default("one_time") @map("fund_type")
  status           String?  @default("active")
  notes            String?
  createdBy        Int?     @map("created_by")
  year             Int      @default(2026)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  creator  User?            @relation("SponsorCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  payments SponsorPayment[]

  @@index([year])
  @@map("sponsors")
}

model SponsorPayment {
  id            Int      @id @default(autoincrement())
  sponsorId     Int      @map("sponsor_id")
  amount        Decimal  @db.Decimal(15, 2)
  paymentDate   DateTime @default(now()) @map("payment_date") @db.Date
  paymentMethod String?  @default("cash") @map("payment_method")
  notes         String?
  createdBy     Int?     @map("created_by")
  year          Int?
  month         Int?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sponsor Sponsor @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  creator User?   @relation("SponsorPaymentCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([sponsorId])
  @@index([year])
  @@index([month])
  @@map("sponsor_payments")
}

model AttendanceRecord {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  sessionDate      DateTime  @map("session_date") @db.Date
  sessionType      String    @map("session_type")
  status           String    @default("present")
  checkInTime      DateTime? @map("check_in_time") @db.Time
  checkOutTime     DateTime? @map("check_out_time") @db.Time
  lateMinutes      Int       @default(0) @map("late_minutes")
  notes            String?
  markedBy         Int?      @map("marked_by")
  communicated     Boolean   @default(false)
  disciplinePoints Int       @default(0) @map("discipline_points")
  onTime           Boolean   @default(false) @map("on_time")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user   User  @relation("AttendanceUser", fields: [userId], references: [id], onDelete: Cascade)
  marker User? @relation("AttendanceMarker", fields: [markedBy], references: [id], onDelete: SetNull)

  @@unique([userId, sessionDate, sessionType])
  @@index([userId, sessionDate])
  @@index([sessionDate])
  @@index([sessionType])
  @@map("attendance_records")
}

model AttendanceSession {
  sessionDate DateTime  @map("session_date") @db.Date
  sessionType String    @map("session_type")
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  completedBy Int?      @map("completed_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  completer User? @relation("AttendanceSessionCompleter", fields: [completedBy], references: [id], onDelete: SetNull)

  @@id([sessionDate, sessionType])
  @@index([sessionDate])
  @@map("attendance_sessions")
}

model PermissionRequest {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  type            String
  startDate       DateTime  @map("start_date") @db.Date
  endDate         DateTime  @map("end_date") @db.Date
  reason          String
  status          String    @default("pending")
  approvedBy      Int?      @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason")
  attachmentUrl   String?   @map("attachment_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user     User  @relation("PermissionRequester", fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("PermissionApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status])
  @@map("permission_requests")
}

model DisciplineSection {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  records DisciplineRecord[]

  @@map("discipline_sections")
}

model DisciplineRecord {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  sectionId     Int?      @map("section_id")
  title         String
  description   String?
  points        Int       @default(0)
  type          String?
  status        String    @default("active")
  recordedBy    Int?      @map("recorded_by")
  resolvedBy    Int?      @map("resolved_by")
  resolvedAt    DateTime? @map("resolved_at")
  resolvedNotes String?   @map("resolved_notes")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user     User               @relation("DisciplineUser", fields: [userId], references: [id], onDelete: Cascade)
  section  DisciplineSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  recorder User?              @relation("DisciplineRecorder", fields: [recordedBy], references: [id], onDelete: SetNull)
  resolver User?              @relation("DisciplineResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([sectionId])
  @@map("discipline_records")
}

model Playlist {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  createdBy   Int?     @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator User?          @relation("CreatedPlaylists", fields: [createdBy], references: [id], onDelete: SetNull)
  songs   PlaylistSong[]

  @@index([createdBy])
  @@map("playlists")
}

model Song {
  id             Int      @id @default(autoincrement())
  title          String
  artist         String?
  keySignature   String?  @map("key_signature")
  tempo          Int?
  lyrics         String?
  youtubeLink    String?  @map("youtube_link")
  assignedSinger String?  @map("assigned_singer")
  createdBy      Int?     @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  creator   User?          @relation("CreatedSongs", fields: [createdBy], references: [id], onDelete: SetNull)
  playlists PlaylistSong[]

  @@index([createdBy])
  @@index([title])
  @@map("songs")
}

model PlaylistSong {
  id           Int      @id @default(autoincrement())
  playlistId   Int      @map("playlist_id")
  songId       Int      @map("song_id")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song     Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([playlistId, songId])
  @@index([songId])
  @@map("playlist_songs")
}

model PhotoGallery {
  id          Int       @id @default(autoincrement())
  title       String
  imagePath   String    @map("image_path")
  description String?
  eventDate   DateTime? @map("event_date") @db.Date
  createdBy   Int?      @map("created_by")
  category    String?
  tags        String?
  altText     String?   @map("alt_text")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  creator User? @relation("CreatedGallery", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([createdBy])
  @@index([createdAt])
  @@map("photo_gallery")
}

model ServiceTeam {
  id            Int       @id @default(autoincrement())
  serviceName   String    @map("service_name")
  numberOfTeams Int       @default(1) @map("number_of_teams")
  generatedAt   DateTime  @default(now()) @map("generated_at")
  createdBy     Int?      @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  serviceDate   DateTime? @map("service_date") @db.Date

  creator User?        @relation("CreatedServiceTeams", fields: [createdBy], references: [id], onDelete: SetNull)
  members TeamMember[]

  @@index([createdBy])
  @@index([createdAt])
  @@map("service_teams")
}

model TeamMember {
  id               Int      @id @default(autoincrement())
  serviceTeamId    Int?     @map("service_team_id")
  teamNumber       Int      @map("team_number")
  userId           Int?     @map("user_id")
  voicePart        String?  @map("voice_part")
  performanceLevel String?  @map("performance_level")
  createdAt        DateTime @default(now()) @map("created_at")

  serviceTeam ServiceTeam? @relation(fields: [serviceTeamId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([serviceTeamId])
  @@index([userId])
  @@map("team_members")
}

model PublicBoardItem {
  id          Int       @id @default(autoincrement())
  title       String
  content     String
  isPinned    Boolean   @default(false) @map("is_pinned")
  createdBy   Int?      @map("created_by")
  type        String    @default("update")
  eventDate   DateTime? @map("event_date")
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  creator User? @relation("CreatedBoardItems", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([createdBy])
  @@index([isPublished])
  @@index([isPinned, createdAt])
  @@map("public_board")
}

model LandingYoutubeVideo {
  id          Int      @id @default(autoincrement())
  title       String
  youtubeId   String   @map("youtube_id")
  isPublished Boolean  @default(false) @map("is_published")
  sortOrder   Int      @default(0) @map("sort_order")
  createdBy   Int?     @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator User? @relation("CreatedLandingVideos", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([createdBy])
  @@index([sortOrder])
  @@map("landing_youtube_videos")
}

model LandingFeaturedImage {
  id          Int      @id @default(autoincrement())
  title       String
  imagePath   String   @map("image_path")
  description String?
  isPublished Boolean  @default(false) @map("is_published")
  sortOrder   Int      @default(0) @map("sort_order")
  createdBy   Int?     @map("created_by")
  isHero      Boolean  @default(false) @map("is_hero")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator User? @relation("CreatedFeaturedImages", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([createdBy])
  @@index([sortOrder])
  @@map("landing_featured_images")
}

model SpiritualForm {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  questions   Json     @default("[]")
  settings    Json     @default("{}")
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   Int?     @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator     User?            @relation("CreatedSpiritualForms", fields: [createdBy], references: [id], onDelete: SetNull)
  submissions FormSubmission[]

  @@index([createdBy])
  @@index([isActive])
  @@map("forms")
}

model FormSubmission {
  id           Int       @id @default(autoincrement())
  formId       Int       @map("form_id")
  userId       Int?      @map("user_id")
  answers      Json      @default("{}")
  manualGrades Json?     @map("manual_grades")
  score        Float?
  isReleased   Boolean   @default(false) @map("is_released")
  releasedAt   DateTime? @map("released_at")
  submittedAt  DateTime  @default(now()) @map("submitted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  form SpiritualForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  user User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([formId])
  @@index([userId])
  @@map("form_submissions")
}

model Announcement {
  id             Int       @id @default(autoincrement())
  title          String
  content        String
  type           String    @default("general")
  priority       String    @default("normal")
  status         String    @default("active")
  scheduledDate  DateTime? @map("scheduled_date") @db.Date
  expiryDate     DateTime? @map("expiry_date") @db.Date
  targetAudience String?   @map("target_audience")
  targetType     String    @default("all") @map("target_type")
  targetRoles    String?   @map("target_roles")
  targetUsers    String?   @map("target_users")
  imagePath      String?   @map("image_path")
  emailSent      Boolean   @default(false) @map("email_sent")
  createdBy      Int?      @map("created_by")
  publishedBy    Int?      @map("published_by")
  publishedAt    DateTime? @map("published_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  creator   User?                  @relation("CreatedAnnouncements", fields: [createdBy], references: [id], onDelete: SetNull)
  publisher User?                  @relation("PublishedAnnouncements", fields: [publishedBy], references: [id], onDelete: SetNull)
  reads     AnnouncementUserRead[]

  @@index([status])
  @@index([targetType])
  @@index([createdBy])
  @@index([publishedBy])
  @@map("announcements")
}

model AnnouncementUserRead {
  id             Int      @id @default(autoincrement())
  announcementId Int      @map("announcement_id")
  userId         Int      @map("user_id")
  readAt         DateTime @default(now()) @map("read_at")

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
  @@map("announcement_user_reads")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePageFeature[]

  @@map("roles")
}

model UserRole {
  userId    Int      @map("user_id")
  roleId    Int      @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("role_user")
}

model Page {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  label       String
  description String?
  icon        String?
  href        String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  features    Feature[]
  permissions RolePageFeature[]

  @@index([isActive, sortOrder])
  @@map("pages")
}

model Feature {
  id          Int      @id @default(autoincrement())
  pageId      Int      @map("page_id")
  name        String
  label       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  page        Page              @relation(fields: [pageId], references: [id], onDelete: Cascade)
  permissions RolePageFeature[]

  @@unique([pageId, name])
  @@index([name])
  @@map("features")
}

model RolePageFeature {
  roleId    Int      @map("role_id")
  pageId    Int      @map("page_id")
  featureId Int      @map("feature_id")
  createdAt DateTime @default(now()) @map("created_at")

  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  page    Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([roleId, pageId, featureId])
  @@index([pageId])
  @@index([featureId])
  @@map("role_page_features")
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json?
  group     String   @default("general")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@map("system_settings")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String
  module    String?
  metadata  Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@map("activity_logs")
}

model Notification {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  type       String
  title      String
  message    String
  link       String?
  sourceType String?   @map("source_type")
  sourceId   Int?      @map("source_id")
  dedupeKey  String?   @unique @map("dedupe_key")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  email EmailDelivery?

  @@index([userId, readAt, createdAt])
  @@index([sourceType, sourceId])
  @@map("notifications")
}

model EmailDelivery {
  id             Int       @id @default(autoincrement())
  userId         Int?      @map("user_id")
  notificationId Int?      @unique @map("notification_id")
  recipient      String
  subject        String
  text           String
  html           String?
  status         String    @default("pending")
  attempts       Int       @default(0)
  lastError      String?   @map("last_error")
  nextAttemptAt  DateTime? @map("next_attempt_at")
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)

  @@index([status, nextAttemptAt])
  @@index([recipient])
  @@map("email_deliveries")
}
